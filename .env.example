# Portfolio Environment Variables Example

# Backend Settings
SECRET_KEY=django-insecure-your-super-secret-key-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,.onrender.com,.vercel.app

# Database (Neon / Supabase PostgreSQL or SQLite for local dev)
DATABASE_URL=postgres://user:password@localhost:5432/portfolio_db

# CORS Settings
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Email Settings (Contact Form Notifications)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=your-email@gmail.com
ADMIN_EMAIL=sathish.kumar@example.com

# Frontend API URL
VITE_API_BASE_URL=http://127.0.0.1:8000/api/v1
